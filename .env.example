# Copy this file to .env (git-ignored) and fill in real values.
# Loaded automatically by the backend on startup, no matter how it's launched
# (mvn -f back/avento/pom.xml spring-boot:run, an IDE run config, or java -jar).
#
# ./scripts/dev-up.sh generates AVENTO_AUTH_ROOT_PASSWORD here for you on first run
# if it's missing.

# Required: no built-in default. The app refuses to start without it.
AVENTO_AUTH_ROOT_EMAIL=admin@avento.local
AVENTO_AUTH_ROOT_PASSWORD=

# Change this before exposing the backend beyond 127.0.0.1.
AVENTO_AUTH_JWT_SECRET=dev-only-change-me-avento-local-auth-secret-32-bytes

# Local PostgreSQL password used by docker-compose.yml and dev-up.sh.
AVENTO_DATASOURCE_PASSWORD=avento_dev_password

# Optional: enables the read-only Postgres MCP tool when set.
AVENTO_MCP_POSTGRES_CONNECTION_STRING=

# Official MCP Java SDK. External MCP servers require this path.
AVENTO_MCP_SDK_ENABLED=true
AVENTO_MCP_SDK_REQUEST_TIMEOUT=60s
AVENTO_MCP_AUTO_CONNECT=filesystem,markitdown,memory,sequential-thinking,time,desktop-commander,macos-automator,apple,playwright,chrome-devtools,puppeteer,git

# dev-up.sh starts a local Ollama server when one is not already responding.
AVENTO_OLLAMA_AUTOSTART=1

# Isolates disposable npx MCP packages from a stale or corrupt global npm cache.
AVENTO_NPM_CACHE_DIR=.avento-tools/npm-cache

# Optional reproducible MCP package overrides. Defaults are pinned in application.yml.
# AVENTO_MCP_PLAYWRIGHT_PACKAGE=@playwright/mcp@0.0.78
# AVENTO_MCP_DBHUB_PACKAGE=@bytebase/dbhub@0.23.0

# Optional: fallback chat model used only when a request arrives without a model
# (the model picked in the frontend selector always wins when present).
AVENTO_AGENT_DEFAULT_MODEL=qwen3:8b
# Model selected automatically when the conversation contains an attached image.
AVENTO_AGENT_VISION_MODEL=qwen2.5vl:7b

# Any other AVENTO_* setting from application.yml can also be overridden here.

# Optional when launching the backend without scripts/dev-up.sh. Relative voice
# paths are resolved from this directory; the script exports it automatically.
AVENTO_PROJECT_ROOT=

# Local voice tuning. VAD removes silence before transcription; Piper values tune prosody.
AVENTO_VOICE_VAD_ENABLED=true
AVENTO_VOICE_VAD_THRESHOLD=0.50
AVENTO_VOICE_VAD_MIN_SILENCE_MS=550
AVENTO_VOICE_VAD_SPEECH_PAD_MS=120
AVENTO_VOICE_PIPER_MODEL_PT=./piper_tts/pt_BR-dii-high.onnx
AVENTO_VOICE_PIPER_MODEL_EN=./piper_tts/en_US-lessac-medium.onnx
AVENTO_VOICE_PIPER_LENGTH_SCALE=0.95
AVENTO_VOICE_PIPER_NOISE_SCALE=0.60
AVENTO_VOICE_PIPER_NOISE_WIDTH_SCALE=0.80
AVENTO_VOICE_PIPER_SENTENCE_SILENCE=0.18
